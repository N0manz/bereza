# --- Postgres ---
POSTGRES_DB=bereza
POSTGRES_USER=bereza
POSTGRES_PASSWORD=bereza

# --- Backend ---
DB_URL=jdbc:postgresql://postgres:5432/bereza
DB_USER=bereza
DB_PASSWORD=bereza
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# Включить secure-cookies, когда фронт работает по HTTPS
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Соль для remember-me
REMEMBER_ME_KEY=please-change-me

# CORS / WebSocket — список Origin через запятую
ALLOWED_ORIGINS=https://bereza.example.ru

# Файловое хранилище (внутри контейнера / volume)
STORAGE_ROOT=/app/var/storage

# --- Frontend (build-time) ---
VITE_API_BASE=/api
VITE_WS_BASE=/ws
