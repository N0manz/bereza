  "theme": "base",
  "themeVariables": {
    "primaryColor": "#E8EAF6",
    "primaryTextColor": "#1A237E",
    "primaryBorderColor": "#3949AB",
    "lineColor": "#546E7A",
    "background": "#FFFFFF",
    "mainBkg": "#FFFFFF",
    "clusterBkg": "#F8F9FA",
